# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=tourplanner
POSTGRES_USER=tourplanner
POSTGRES_PASSWORD=changeme

# ─── Backend ─────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Connection string is built from above values in docker-compose
# For local dotnet run outside docker:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=tourplanner;Username=tourplanner;Password=changeme

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_ISSUER=TourPlanner
JWT_AUDIENCE=TourPlannerUsers
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# OpenRouteService API key (backend only — never expose to frontend)
ORS_API_KEY=

# Image storage base path (inside container it's /app/images)
IMAGES_BASE_PATH=/app/images

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Leave empty to use relative /api requests through the frontend dev/prod proxy.
# For a non-proxied frontend, set an absolute URL such as http://localhost:5000.
VITE_API_BASE_URL=
